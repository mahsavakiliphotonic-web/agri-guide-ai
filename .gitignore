# =============================================
# AgriGuide AI - .gitignore
# =============================================

# 🔒 SECURITY - API Keys & Secrets (NEVER push these)
.env
.env.*
.env.local
*.pem
*.key
*.cert

# 📦 Dependencies (auto-installed via: npm install)
/node_modules

# 🏗️ Build output (auto-generated via: npm run dev)
/.next/
/out/
/build

# 🖥️ OS files (auto-generated by Windows/Mac)
.DS_Store
Thumbs.db
